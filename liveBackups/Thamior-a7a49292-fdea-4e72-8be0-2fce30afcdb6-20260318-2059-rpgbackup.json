{"uuid":"01923e4d-7860-7d15-b01c-9f518422c4e6","characterName":"Thamior","characterStats":[{"statUuid":"bb3b77c1-cbdb-49b4-b2b5-6b24d20f4383","serializedValue":"{\"value\":0}","hideFromCharacterScreen":null,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"886df3c2-a93f-47ae-931f-86153997860d","serializedValue":"{\"value\":14}","hideFromCharacterScreen":null,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"082e62cb-7c17-4702-8529-172fb8e74c04","serializedValue":"{\"value\":9}","hideFromCharacterScreen":null,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"97a52844-977b-445f-9df1-e542ab3b49fe","serializedValue":"{\"value\":2}","hideFromCharacterScreen":null,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"31a52ed2-3e7b-42ac-8f3e-490b3a04027a","serializedValue":"{\"values\":[]}","hideFromCharacterScreen":null,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"212b9948-bc45-48f1-af39-bc84d6c5283f","serializedValue":"{\"values\":[]}","hideFromCharacterScreen":null,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"f8b49ed4-a24a-45fb-8077-369fde7ef37c","serializedValue":"{\"values\":[]}","hideFromCharacterScreen":null,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"612f5698-fdda-4485-b138-599ae3532520","serializedValue":"{\"values\":[]}","hideFromCharacterScreen":null,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"347e51fa-caf0-4054-8eb9-dac3ba48c281","serializedValue":"{\"values\":[]}","hideFromCharacterScreen":null,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"2438aac8-4a67-41ca-aad9-3c838b7c5cf3","serializedValue":"{\"value\":0,\"maxValue\":0}","hideFromCharacterScreen":true,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"18877c24-515a-4788-a657-d50915a5c0cc","serializedValue":"{\"value\":0,\"maxValue\":0}","hideFromCharacterScreen":true,"hideLabelOfStat":null,"variant":2,"isCopy":false},{"statUuid":"cae3e22b-5674-4728-82d4-c8a28615fcdd","serializedValue":"{\"value\":0,\"maxValue\":0}","hideFromCharacterScreen":true,"hideLabelOfStat":null,"variant":2,"isCopy":false},{"statUuid":"66f0e8dd-1fed-47d8-9e4d-88e0b8b2e2b0","serializedValue":"{\"value\":0,\"maxValue\":0}","hideFromCharacterScreen":true,"hideLabelOfStat":null,"variant":2,"isCopy":false},{"statUuid":"f4268470-6c7c-4fc8-8412-cf2fea4e19b1","serializedValue":"{\"value\":0,\"maxValue\":0}","hideFromCharacterScreen":true,"hideLabelOfStat":null,"variant":2,"isCopy":false},{"statUuid":"940ef581-e6a5-4dcd-bb9d-567a0294a76d","serializedValue":"{\"value\":0,\"maxValue\":0}","hideFromCharacterScreen":true,"hideLabelOfStat":null,"variant":2,"isCopy":false},{"statUuid":"c1b7a131-c239-4d56-8008-b3d4b654189d","serializedValue":"{\"values\":[\"c247bc4f-f04b-4301-a401-fe0908eb3ca9\"]}","hideFromCharacterScreen":false,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"893bab17-6c13-4ed5-a287-8eaa135a54ef","serializedValue":"{\"value\":\"# Giftmischer-Set:\\nInhalt\\n- 3 Beutel, um Kräuter zu bewahren\\n- Einige gebräuchliche Basis-Chemikalien\\n- Mörser und Stößel\\n- 1 Glas-Rührstab\\n- 5 Glasfläschchen\\n\\n## Skill Checks\\n- Geschichte: Durch den Übungsbonus mit dem Set bekommt der Spieler den Übungsbonus auch, wenn er versucht sich an die Fakten von berühmten Vergiftungsfällen zu erinnern.\\n- Nachforschen & Wahrnehmen: Dein Wissen über Gifte hat dich einen vorsichtigen Umgang mit diesen Substanzen gelehrt. Wenn du vergiftete Objekte oder Ereignisse, die in Zusammenhang mit Gift stehen, untersuchst, kannst du deinen Übungsbonus verwenden.\\n- Heilkunde: Wenn du Gift-Opfer behandelst, kannst du deinen Übungsbonus anwenden.\\n- Naturkunde & Überlebenskunst: Du hast Vorteil beim Erkennen von giftigen Pflanzen und\\nKreaturen.\\n\\n## Gifte herstellen\\n-> Übungsbonus kann zu Checks dazugerechnet werden\\n- Gewöhnliche Rezepte: Brauchen die genannten Zutaten und 8h Arbeit\\n- Ungewöhnliche Rezepte: Brauchen die genannten Zutaten und 12h Arbeit\\n- Seltene Rezepte: Brauchen die genannten Zutaten und 24h Arbeit\\n- Sehr seltene Rezepte: Brauchen die genannten Zutaten und 48h Arbeit\\n\\n## Regeln für das Sammeln und Ernten von Zutaten:\\nWenn ein Gebiet Pflanzen, Pilze oder anderes beherbergt, das für Gifte gesammelt und geerntet werden können, muss ein Spieler einen Naturkunde Check machen (je nach Wurf werden gewöhnliche, ungewöhnliche und seltene Zutaten entdeckt) -> mit Vorteil\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01934fcc-db6d-74ef-b6b7-794c5a0ef970","serializedValue":"{\"value\":\"# Schurke Assassine\\n\\n## Stufe 3\\nAssassinentricks: Du bist geübt mit dem Giftmischer-Set und bist bei allen Würfen in Verbindung damit im Vorteil. Zusätzlich kannst Du deinen Übungsbonus auf deine initiativewürfe addieren und Kletter kostet dich keine zusätzliche Bewegung mehr.\\n\\nAttentat: Als lautloser Killer bist Du geübt darin die Schwachstelle eines Gegners auszunutzen. Du bist im Vorteil bei Angriffswürfen gegen Kreaturen, die in einem Kampf noch nicht am Zug waren. Außerdem ist jeder Treffer gegen einen überraschten Gegner automatisch kritisch.\\nWenn du einen kritischen Treffer landest und bei einem Schadenswürfe eine 1 wirfst, darfst du erneut würfeln.\\n\\nVergiftete Klinge: Du attackierst gerne geräuschlos und aus dem Hinterhalt, nur um sofort danach wieder zu verschwinden, Du kannst die Bonusaktion deiner raffinierten Aktion nutzen, um eine Waffe in Gift zu tauchen. Beim nächsten Angriff mit dieser Waffe kannst du deinen hinterhältigen Angriff anwenden und verursachst damit nekrotischen Schaden.\\n\\nFlinke Finger: Du kannst deine Bonusaktion für einen Wurf auf Geschicklichkeit (Fingerfertigkeit), den Einsatz von Diebeswerkzeug, um ein Schloss zu öffnen, eine Falle zu entschärfen oder um ein Objekt zu verwenden, nutzen.\\n\\n## Stufe 9\\nErfahrener Killer: Du bist bei Würfen für Geschicklichkeit (Heimlichkeit) im Vortell, wenn au noch mehr als die Hälfte deiner Bewegung übrig hast.\\nGiftmischer: Durch deine Erfahrung mit Giften bist du resistent gegen Giftschaden und im Vorteil bei Rettungswürfen gegen den „Vergiftet\\\"-Zustand.\\nWährend einer beliebigen Rast kannst du das Giftmischer-Set nutzen um von einem einfachen Gift\\neine Anzahi von Dosen in Höhe deines Übungsbonus' herzustellen. Du\\nentscheidest, um das Gift bei Kontakt, bei Verletzungen, beim Einnehmen oder beim Einatmen wirkt. Du stellst dies aus durchschnittlichen Substanzen her, die in jedem Haushalt oder der freien Wildnis zu finden sind und brauchst keine speziellen Komponenten. Eine Kreatur, die diesem Gift ausgesetzt ist, muss einen Konstitutionsrettungswurf gegen einen DC von 8 + deinen intelligenzmodifikator + deinen Übungsbonus ablegen und erleidet bei einem Misserfolg Schaden in Höhe deines Schurkenlevels + deinen Übungsbonus. Bei einem Erfolg erleidet die Kreatur nur die Hälfte des Schadens.\\n\\n## Stufe 13\\nTodbringer: Du schlägst blitzschnell zu, um einen raschen Tod zu bereiten. Du würfelst deine Initiative mit Vorteil, wenn du versteckt bist und die Schadenswürfel deines hinterhältigen Angriffs sind nun d8er.Meister der Gifte: Du kannst Gifte speziell für den Typus einer Klasse herstellen, das Resistenz und Immunität ignoriert, außer der Schwierigkeitsgrad der Kreatur ist höher als dein Schurkenlevel + deinen Übungsbonus.\\n\\n## Stufe 17\\nModus Operandi: im ersten Durchgang eines Kampfes kannst Du zwei Züge ausführen, wenn Du nicht überrascht bist. Du greifst einmal bei der regulär gewürfelten Initiative an und noch einmal bei Initiative 10\\nTodesstoß: Einmal pro beliebiger Rast kannst Du einen hinterhältigen Angriff zu einem Kritischen Treffer umwandeln, wenn er trifft.\\nBei Angriffen gegen eine überraschte Kreatur muss diese bei einem Treffer einen Konstitutionsrettungswurf gegen einen DC von 8 + Deinen Geschicklichkeitsmodifikator + deinen Übungsbonus ablegen und erleidet bei einem Misserfolg doppelten Schaden.\\nGnadenstoß: Wenn eine Kreatur nach deinem hinterhältigen Angriff weniger HP ais 2x dein Schurkenlevel hat, muss sie ebenfalls einen Konstitutionsrettungswurf ablegen, wobei ein Misserfolg zum sofortigen Tod führt. Eine überraschte Kreatur, die Du mit einem kritischen Treffer getroffen hast, ist bei diesem Rettungswurf im Nachteil.\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01935fa2-484e-7cbb-baa8-006a246421f4","serializedValue":"{\"value\":\"\"}","hideFromCharacterScreen":true,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01935fa3-48d0-7cda-a1e2-100cb98c25ef","serializedValue":"{\"value\":\"\"}","hideFromCharacterScreen":true,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01935fa4-05d3-71ff-a358-227e41934eaf","serializedValue":"{\"value\":\"\"}","hideFromCharacterScreen":true,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"64be408b-ebbb-49fb-97af-da69c6c91fe3","serializedValue":"{\"value\":\"Mondelf\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"cb2ee5ff-73d9-43e7-9e45-eca3a585bf11","serializedValue":"{\"value\":\"Schurke\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"30e18433-748d-458c-bd5e-373c38e762bf","serializedValue":"{\"value\":\"Port Borsum; Hausboot\\n\\n# Charakter-Informationen\\nDu bist in Port Borsum aufgewachsen und deshalb kennst du noch ein paar andere Leute und Orte der Stadt:\\n• Donaar, ein Drachengeborener mit hellblau-türkisen Schuppen, der ein Bootsbauer ist und an den Docks lebt\\n• Cogswell Orleth, ein menschlicher Adliger aus Port Borsum, der mit Gewürzen handelt\\n• Zum betrunkenen Oktopus, die beste Taverne der Stadt (und günstig ist sie auch noch); die Gastwirtin ist Annie Stine, eine ungewöhnlich große Elfe, die zu jedem nett ist, bei Kneipenschlägereien aber hart und entschieden durchgreift\\n• Das Seven Seas, ein Gasthof, bei dem man das Beste für den kleinsten Preis bekommt; die Betten sind immer sauber. Der Gastwirt ist Milton Emmerkin, ein dünner Halbling, der immer ein Zimmer frei lässt, falls seine Soldaten-Tochter mal zu Besuch kommen sollte\\nLeute, deren Namen du kennst, weil sie wichtige Stellungen in der Stadt/im Land innehaben:\\n• Evendur Havercrown, der König von Efari (Mensch), er gutmütiger König, der während seiner Regentschaft keine großen Hürden überwinden musste. Er unterhält ein sehr freundschaftliches Verhältnis zum Nachbarkönigreich Sachaka, seit er seine Tochter an den dortigen Sultan verheiratet hat. Port Borsum gehört so auch zu beiden\\nKönigreichen.\\n• Zasheir Khalid, der Sultan von Sachaka (Mensch); heiratete die Prinzessin von Efari, um das Bündnis zwischen den Ländern zu stärken\\n• Korvax Quorn, der General von Port Borsums Militär (Mensch)\\n• Annadema Ellicanth, eine elfische Adlige, die ihren Stand nicht durch Reichtum, sondern durch Verwandtschaft erlangt hat\\nHier sind noch ein paar Fragen, über die du nachdenken könntest, um deinen Charakter etwas auszubauen. Du musst nicht auf alles eine Antwort finden (und definitiv auch nicht sofort), aber vielleicht fällt dir zu ein paar Sachen noch etwas ein. :)\\n• Woher hast du das Boot? (Hast du es gestohlen? Hast du es gefunden? Hast du es als Belohnung für einen Auftrag bekommen? Wenn ja, was war der Auftrag? Hast du es von Donaar, dem Bootsbauer, geschenkt bekommen?) von meinem Eltern\\n• Hast du eine falsche Identität? (Gehört zum Scharlatan-Hintergrund, S. 128?) ja\\n• Wie bist du aufgewachsen? (Waren deine Eltern eher streng oder fürsorglich?\\nGehörtest du zur Oberschicht oder bist du eher arm aufgewachsen?) Adelige Familie\\n• Hast du Geschwister? Ja zwei Brüder Thionel & Thiodoro\\n• Wer ist im Moment dein bester Freund bzw. die Person, die dir am nächsten steht?\\n• Wie sieht die Beziehung zu deinen Eltern aus? (Leben sie noch? Wenn ja, leben sie noch in Port Borsum? Wissen sie, was du machst?)\\nSie sind ausgewandert, sie wissen was ich mache\\n• Hast du Feinde oder Rivalen? Wenn ja, warum? Brüder\\n• Wie haben du und Kardan (Peter) euch kennengelernt? (Mit Peter besprechen) Bergen\\n• Wie sieht eure Beziehung zueinander aus? (Mit Peter besprechen) gut\\n\\nAm besten überlegst du dir noch, welche Gesinnung dein Charakter hat (S. 122?) →> „böse\\\" ist dabei eher egoistisch und selbstsüchtig, statt wirklich bösartig (rechtschaffend böse). Und guck bei deinem Hintergrund noch mal nach, was eventuell Persönlichkeits-merkmale, Ideale, Bindungen und Makel sein könnten (auf S. 128? Gibt es Vorschlage, aber du kannst dir auch etwas eigenes überlegen).\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"0070b224-95ac-4f0f-ab07-1ddb0d3d2ac8","serializedValue":"{\"value\":\"Scharlatan\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"37862834-261a-47b5-bd5c-9e315b8d26aa","serializedValue":"{\"value\":\"Rechtschaffend-böse\\n\\n# Persönlichkeitsmerkmale\\nIch kenne einen Witz für jede Situation, besonders für die, in denen Humor unangebracht ist.\\n\\n# Ideale\\nEhrgeiz: Ich bin zu größerem bestimmt als kleine Betrügereinen auf der Straße.\\n\\n# Bindung\\nIch stamme aus einer adeligen Familie.\\n\\n# Makel\\nIch kann einem schönen Gesicht nicht widerstehen.\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"a464bfe4-d99f-475d-a4af-0f1e5f73290e","serializedValue":"{\"value\":\"\"}","hideFromCharacterScreen":false,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"5accd34c-eade-4754-b955-21e1d902c4d9","serializedValue":"{\"value\":\"- Dunkelsicht 18m\\n- Feenblut: bei Rettungswürfen Vorteil gegen Betäubungszauber; immun gegen Schlafzauber\\n- Trance: 4 Stunden Meditation\\n- Lieblingsmasche: Identität wechseln\\n- elfische Waffenvertrautheit: Lang-& Kurzschwerte; Lang-& Kurzbögen\\n- Zaubertrick: ?\\n- zusätzliche Sprache: Infernalisch\\n- Diebessprache\\n\\n- leichte Rüstung\\n- Waffen: einfache Waffen, Handarmbrüste, Langschwerter, Rapiere & Kurzschwerter\\n\\n- Vorteil für das Sammeln und Ernten von Zutaten: Naturkunde Check \"}","hideFromCharacterScreen":false,"hideLabelOfStat":null,"variant":0,"isCopy":false},{"statUuid":"01935fa1-7723-7efc-a584-b07a091a422b","serializedValue":"{\"value\":\"4d8\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"019312bf-ab08-7b56-94ff-e35cb4c61c31","serializedValue":"{\"value\":\"Hellblauer Mondelf (männlich) mit Assassinen Kleidung in dunkelblau mit goldenen Akzenten. Im Hintergrund soll ein fliegendes Schiff sein.\\n\",\"imageUrl\":\"/public/getimage/98ece8bb-1c22-47fc-9ca8-2a28d79e98c9/M8U7yAn94JYrKBgulwYa2IhEEqMKI6UwW6u5AhKFvio=\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01931632-8c9e-7c14-bf39-d2e440039498","serializedValue":"{\"values\":[{\"uuid\":\"01931631-08c5-7ed8-9625-5814402a6671\",\"value\":18,\"otherValue\":4},{\"uuid\":\"01931631-0a87-7a18-8e51-79209e0f5a46\",\"value\":13,\"otherValue\":1},{\"uuid\":\"01931631-0c07-7c0a-8855-b10c01b5be3b\",\"value\":11,\"otherValue\":0},{\"uuid\":\"01931631-1085-7fe7-ba45-e32a490cc859\",\"value\":14,\"otherValue\":2},{\"uuid\":\"01931631-1497-71c5-9844-fac61fe5c8c1\",\"value\":14,\"otherValue\":2},{\"uuid\":\"01931631-182c-775e-896a-7a1a5d051d55\",\"value\":15,\"otherValue\":2}]}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"c5ef782a-8d8b-4a88-98b2-be277f741e4c","serializedValue":"{\"values\":[\"89f12e22-178a-4d87-8517-4fe4787335f3\",\"3196199d-f023-4289-a8ce-e5659d54deae\",\"9ab19470-306b-4be0-a23d-ab8bc9c79e0d\",\"9ab19470-306b-4be0-a23d-ab8bc9c79e0d\",\"a3040091-cf15-4e63-87b7-3c449a9b3dd4\",\"a3040091-cf15-4e63-87b7-3c449a9b3dd4\",\"072ea46a-043c-4548-bb2d-9d340691d940\",\"827f2550-9683-45cf-b8fb-cad229c47fe8\",\"01931c9f-b24b-7690-8a44-d5120535bc12\"]}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":1,"isCopy":false},{"statUuid":"1ce2f567-d540-498a-a677-9776d518622d","serializedValue":"{\"values\":[\"3dbb5cb6-f256-4dfd-acae-ead1baedb27f\",\"a3c9cd51-bd58-4d01-b7bb-fe9dcd27f349\"]}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01935ab0-32e5-7b4b-8017-9a7f4d63c687","serializedValue":"{\"values\":[{\"uuid\":\"01935bd2-5082-7924-baa1-55d74d27cac7\"},{\"uuid\":\"01935bd2-43ae-7531-8394-c5cba337f4dd\"}]}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01935fa0-266a-7353-9010-0f9883388064","serializedValue":"{\"values\":[{\"uuid\":\"01935f9e-b62c-7fda-a781-8fd832ae0b9f\",\"value\":0,\"otherValue\":3},{\"uuid\":\"01935f9e-b864-768d-b231-49290654e74e\",\"value\":0,\"otherValue\":3}]}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01952933-b088-706f-8db5-7da55d761244","serializedValue":"{}","hideFromCharacterScreen":true,"hideLabelOfStat":true,"variant":0,"isCopy":false},{"statUuid":"803f55cb-5d7e-425d-8054-0cb293620481","serializedValue":"{\"value\":38,\"maxValue\":38}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":3,"isCopy":false},{"statUuid":"019317b8-64af-7bb8-9203-6110583f6214","serializedValue":"{\"level\":5,\"values\":[{\"uuid\":\"019317b8-49eb-7575-9f8e-c28c9c8eded2\",\"value\":\"Schurke\"},{\"uuid\":\"019317b8-4bb6-7881-a4db-2a8ec3c751f6\",\"value\":\"Mondelf\"}]}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"0199c855-966a-73de-9421-30516cc59ed8","serializedValue":"{\"value\":0}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01933514-7eef-7523-a4cc-974802dc96e7","serializedValue":"{\"values\":[{\"uuid\":\"01933512-97e4-70fe-877d-0e1f64224a00\",\"value\":14},{\"uuid\":\"01933512-997d-7628-9de3-72827cf4f419\",\"value\":9},{\"uuid\":\"01933512-9cb6-7466-9977-0768e0dda2a7\",\"value\":3}]}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":1,"isCopy":false},{"statUuid":"3219934b-09fc-409b-8413-9e56b864c664","serializedValue":"{\"value\":\"# Attacken\\n- Hinterhältiger Angriff: 1x pro Zug zusätzlich 3W6, falls Vorteil -> Fernwaffen (Wurfmesser) oder Finesse (Rapier)\\n- Raffinierte Aktion: 1 Bonusaktion (Spurt, Rückzug, Verstecken)\\n\\n# Unglaublisches Ausweichen\\n - Wenn ein Angriff eines Gegner trifft, den ich sehen kann, Reaktion aufwenden, um den Schaden des Angriffs zu halbieren\\n - Gegner trifft -> Reaktion aufwenden, um Schaden -50%\\n - Reaktion = einmal pro Runde\\n# Kalte Hand\\n1d20 + Int. (+2) + ÜB (+3)\\n\\n# Rapier\\nGeschicklichkeit +4 plus ÜB +3; beim Treffen und Schaden\\nBeim zweiten Angriff nur ÜB +3\\n\\n# Black Dragon Katana\\nDu erhältst einen Bonus von +1 auf Angriffs- und Schadenswürfe mit dieser magischen\\nWaffe.\\nBeim Treffer verursacht das Katana 1W8 Hiebschaden und zusätzlich 1W4 Säureschaden.\\nSäurestoß (1x pro langer Rast)\\nEinmal pro langer Rast kannst du als Aktion mit dem Katana einen weiten Schlag in die Luft ausführen und eine Linie aus säuregetränkter Klingenenergie vor dich schleudern.\\nDie Attacke erzeugt eine 15 Fuß (4,5 Meter) lange und 5 Fuß (1,5 Meter) breite Linie direkt vor dir in einer Richtung deiner Wahl.\\nAlle Kreaturen in dieser Linie müssen einen Konstitutionsrettungswurf (SG 15) machen.\\n• Bei einem Fehlschlag erleidet eine Kreatur 2W6 Hiebschaden und 2W6 Säureschaden.\\n• Bei einem Erfolg erleidet sie nur die Hälfte des Schadens.\\nDiese Linie trifft alle Kreaturen, die sich innerhalb des Bereichs befinden, auch wenn andere Kreaturen oder Objekte im Weg stehen.\\nNur Kreaturen, die vollständig verdeckt sind (z.B. hinter einer Wand oder fest hinter einem großen Objekt versteckt), werden nicht getroffen.\\n\\n- Angriff: 1W20 + 3ÜB+ Geschicklichkeit 4 + 1 = 1W20 + 7\\n\\n- Schaden: 1W8 (Hiebschaden) + 1W4 (Säureschade)\\n\\n\\n- Säurestoß (1x pro Rast):alle Kreaturen (SG15)\\n\\n     Bei Fehlschlag -> 2W6 Hiebschaden und 2W6 Säureschaden\\n\\n     Bei Erfolg -> 1/2 des Schadens \"}","hideFromCharacterScreen":false,"hideLabelOfStat":true,"variant":0,"isCopy":false}],"isAlternateFormActive":null,"alternateForm":null,"transformationComponents":null,"moneyInBaseType":111025,"tabConfigurations":[{"tabUuid":"8e725f17-ce7c-41d9-a9fd-b83566075096","tabIcon":"spellbook-legend-svgrepo-com"},{"tabUuid":"ebf46bc6-1e1e-4ea2-b580-caa992480e80","tabIcon":"helmet-svgrepo-com"},{"tabUuid":"11cc5da3-624b-40d4-9477-468a0a6b4670","tabIcon":"chess-6-svgrepo-com"},{"tabUuid":"f0c39bb7-1d95-4d7a-aaf2-80bf31f2662a","tabIcon":"sword-svgrepo-com-2"},{"tabUuid":"9421920d-99c2-4882-8a39-53564e7b2920","tabIcon":"magic-wand-witch-svgrepo-com"},{"tabUuid":"money_tab_uuid","tabIcon":"money-bag-svgrepo-com"},{"tabUuid":"inventory_tab_uuid","tabIcon":"backpack-svgrepo-com-2"},{"tabUuid":"recipes_tab_uuid","tabIcon":"halloween-potion-svgrepo-com"},{"tabUuid":"lore_tab_uuid","tabIcon":"treasure-map-svgrepo-com-2"}],"inventory":[{"itemUuid":"01921986-6dbb-706a-8c09-ec79d5be5b9d","amount":2},{"itemUuid":"0191d0e3-8c51-7a58-a019-7266c7af4e3a","amount":67},{"itemUuid":"0191d0f3-55f3-79b4-af97-107593e65e99","amount":27},{"itemUuid":"0191d0fb-935a-7e36-9402-337df6a80315","amount":6},{"itemUuid":"0191d102-b69d-7df7-9b8a-e41827c26579","amount":25},{"itemUuid":"0191d108-d769-7da2-9d64-ba69f610be06","amount":15},{"itemUuid":"0191d115-b297-7f0b-af45-4e0118bbbfeb","amount":29},{"itemUuid":"0191d122-e011-78d1-ae2b-1f8d1840a2a9","amount":1},{"itemUuid":"0191d13a-e5ff-73d9-839f-a420a57ab6c7","amount":8},{"itemUuid":"0191d145-703c-7c73-8053-511c14e4c71b","amount":7},{"itemUuid":"01920bc1-5c79-74fd-b604-c7c825067186","amount":27},{"itemUuid":"01920bc5-599a-783f-8d88-38257ecf78f5","amount":48},{"itemUuid":"01921424-0eca-74bb-bc3d-be2c82996103","amount":35},{"itemUuid":"0192142a-