true,"variant":0,"isCopy":false},{"statUuid":"31a52ed2-3e7b-42ac-8f3e-490b3a04027a","serializedValue":"{\"values\":[]}","hideFromCharacterScreen":true,"hideLabelOfStat":true,"variant":0,"isCopy":false},{"statUuid":"212b9948-bc45-48f1-af39-bc84d6c5283f","serializedValue":"{\"values\":[]}","hideFromCharacterScreen":true,"hideLabelOfStat":true,"variant":0,"isCopy":false},{"statUuid":"f8b49ed4-a24a-45fb-8077-369fde7ef37c","serializedValue":"{\"values\":[]}","hideFromCharacterScreen":true,"hideLabelOfStat":true,"variant":0,"isCopy":false},{"statUuid":"612f5698-fdda-4485-b138-599ae3532520","serializedValue":"{\"values\":[]}","hideFromCharacterScreen":true,"hideLabelOfStat":true,"variant":0,"isCopy":false},{"statUuid":"347e51fa-caf0-4054-8eb9-dac3ba48c281","serializedValue":"{\"values\":[]}","hideFromCharacterScreen":true,"hideLabelOfStat":true,"variant":0,"isCopy":false},{"statUuid":"01935fa4-05d3-71ff-a358-227e41934eaf","serializedValue":"{\"value\":\"\"}","hideFromCharacterScreen":true,"hideLabelOfStat":true,"variant":0,"isCopy":false},{"statUuid":"893bab17-6c13-4ed5-a287-8eaa135a54ef","serializedValue":"{\"value\":\"**Alkoholiker**\\n\\nBetrunken  +1 Charisma (Char)\\n\\n**Gefahrengespühr**\\n\\nBei Geschicklichkeits-Rettungswürfen bei sichtbaren Gefahren im Vorteil\\n\\n**Glückspilz**\\n\\nBei Angriff-, Attributs-, oder Rettungswürfen kann ich **1W20** würfeln und mir das Ergebnis aussuchen. Auch bei Angriffen gegen mich. 3x pro lange Rast wüeinsetzbar. \\n\\n**heilendes Armband**\\n\\nEin Lederarmband, dass dir 1D6 + 3 temporäre HP gibt. Diese Fähigkeit kann nach einer kurzen oder lang rast wieder eingesetzt werden.\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01934fcc-db6d-74ef-b6b7-794c5a0ef970","serializedValue":"{\"value\":\"\"}","hideFromCharacterScreen":true,"hideLabelOfStat":true,"variant":0,"isCopy":false},{"statUuid":"01935fa2-484e-7cbb-baa8-006a246421f4","serializedValue":"{\"value\":\"\"}","hideFromCharacterScreen":true,"hideLabelOfStat":true,"variant":0,"isCopy":false},{"statUuid":"64be408b-ebbb-49fb-97af-da69c6c91fe3","serializedValue":"{\"value\":\"Mensch\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"cb2ee5ff-73d9-43e7-9e45-eca3a585bf11","serializedValue":"{\"value\":\"Barbar\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"30e18433-748d-458c-bd5e-373c38e762bf","serializedValue":"{\"value\":\"Outlander, aus der Wildnis. \\nFühle mich in der Wildnis wohl. \"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"0070b224-95ac-4f0f-ab07-1ddb0d3d2ac8","serializedValue":"{\"value\":\" Ich habe den Zorn der Götter auf mich gezogen. Ich wurde fälschlicherweise in Port Borsum zum Tode durch Galgen verurteilt. In letzter Sekunde konnte ich mich befreien, musste aber einen Wachmann verprügeln.\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"37862834-261a-47b5-bd5c-9e315b8d26aa","serializedValue":"{\"value\":\" Ich bin getrieben Voller Rachust und Zorn den Göttern gegenüber und möchte gleiches mit gleichem vergelten\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"a464bfe4-d99f-475d-a4af-0f1e5f73290e","serializedValue":"{\"value\":\"\"}","hideFromCharacterScreen":true,"hideLabelOfStat":true,"variant":0,"isCopy":false},{"statUuid":"5accd34c-eade-4754-b955-21e1d902c4d9","serializedValue":"{\"value\":\"Common \\nGöttersprache \\nSprache der Orks\\nDrakonisch \\n\\nLeichte und mittlere Rüstung\\nSchilde\\nEinfache Waffen \\nKampfweisen\\nGesang\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01935fa1-7723-7efc-a584-b07a091a422b","serializedValue":"{\"value\":\"\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"803f55cb-5d7e-425d-8054-0cb293620481","serializedValue":"{\"value\":50,\"maxValue\":50}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":1,"isCopy":false},{"statUuid":"019317b8-64af-7bb8-9203-6110583f6214","serializedValue":"{\"level\":5,\"values\":[{\"uuid\":\"019317b8-49eb-7575-9f8e-c28c9c8eded2\",\"value\":\"Barbar \"},{\"uuid\":\"019317b8-4bb6-7881-a4db-2a8ec3c751f6\",\"value\":\"Mensch \"}]}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"01933514-7eef-7523-a4cc-974802dc96e7","serializedValue":"{\"values\":[{\"uuid\":\"01933512-97e4-70fe-877d-0e1f64224a00\",\"value\":16},{\"uuid\":\"01933512-997d-7628-9de3-72827cf4f419\",\"value\":3},{\"uuid\":\"01933512-9cb6-7466-9977-0768e0dda2a7\",\"value\":3}]}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":1,"isCopy":false},{"statUuid":"3219934b-09fc-409b-8413-9e56b864c664","serializedValue":"{\"value\":\"# ⚔️ KAMPF-MENÜ\\n\\n---\\n\\n## 🩸 **1. Angriff (Grundmechanik)**\\n\\n**Trefferwurf:**  \\n`1W20 + Stärke (+4) + Übungsbonus (+3)` → **+7 auf Treffer**\\n\\n**Schadenswurf:**  \\n`[Waffenschadenswürfel] + Stärke (+4)`  \\n*(+2, falls Raserei aktiv ist)*\\n\\n---\\n\\n## ⚔️ **2. Zusätzlicher Angriff**\\n\\n- Wenn du **die Aktion „Angriff“** nutzt → **zweimal angreifen**.  \\n- Wenn du mit einer **einhändigen Nahkampfwaffe** angreifst,  \\n  kannst du deine **Bonusaktion** für **einen weiteren Angriff** mit einer anderen **einhändigen Nahkampfwaffe** verwenden.  \\n  → **Kein Attributsmodifikator** auf den **Schadenswurf** dieses Bonusangriffs.\\n\\n---\\n\\n## 💢 **3. Raserei (Berserker-Fähigkeit)**\\n\\n**Aktivierung:** Vor dem Angriff ansagen  \\n**Verwendungen:** 3× pro **langer Rast**\\n\\n**Effekte:**\\n- +2 **Schaden** bei **Nahkampfangriffen mit Stärke**  \\n- **Resistenz** gegen **Stich-, Hieb- und Wucht-Schaden**\\n\\n---\\n\\n## 🛡️ **4. Rücksichtsloser Angriff**\\n\\n**Aktivierung:** Beim **ersten Angriff** des Zuges ansagen\\n\\n**Effekte:**\\n- **Vorteil** auf alle **Nahkampfangriffe mit Stärke** im Zug  \\n- Gegner haben **Vorteil auf Angriffe gegen dich** bis zum Beginn deines nächsten Zuges\\n\\n---\\n\\n## 🐺 **5. Wolfsomen – Begleiterfähigkeiten**\\n\\n### **Aura des Unglücks**\\n- Alle **feindlichen Kreaturen im Umkreis von 18 m** um das Wolfsomen  \\n  haben **Nachteil** auf:\\n  - **Angriffswürfe**,  \\n  - **Fähigkeitswürfe**,  \\n  - **Rettungswürfe**,  \\n  **gegen dich oder das Wolfsomen**.  \\n- Voraussetzung: Das Wolfsomen befindet sich **innerhalb von 3 m** von dir.  \\n\\n*(Taktischer Hinweis: Halte das Wolfsomen in 3 m Reichweite, um dauerhaft den Nachteil für Gegner zu aktivieren.)*\\n\\n---\\n\\n## ⚙️ **6. Schnellübersicht**\\n\\n| Situation | Trefferbonus | Schaden | Besonderheit |\\n|------------|---------------|----------|---------------|\\n| Normaler Angriff | +7 | Waffenschaden +4 | — |\\n| Mit Raserei | +7 | Waffenschaden +6 | +2 Schaden |\\n| Rücksichtslos + Raserei | Vorteil | Waffenschaden +6 | Vorteil auf Treffer, Gegner haben Vorteil |\\n| Bonusangriff (2. Waffe) | +7 | Waffenschaden | Kein Attribut auf Schaden |\\n\\n---\\n\\n## 🪓 **7. Waffenübersicht**\\n\\n| Waffe | Schaden | Angriffsbonus | Schaden (normal) | Schaden (mit Raserei) | Eigenschaften |\\n|--------|----------|----------------|------------------|------------------------|----------------|\\n| **Dolch** | 1W4 | +7 | 1W4 + 4 | 1W4 + 6 | Finesse, leicht, Wurf (6 m / 18 m Nachteil) |\\n| **Handaxt** | 1W6 | +7 | 1W6 + 4 | 1W6 + 6 | Einhändig, Wurf (6 m / 18 m Nachteil) |\\n| **Kampfstab** | 1W6 (1W8 zweihändig) | +7 | 1W6 + 4 / 1W8 + 4 | 1W6 + 6 / 1W8 + 6 | Vielseitig, Nahkampf |\\n| **Kurzschwert** | 1W6 | +7 | 1W6 + 4 | 1W6 + 6 | Einhändig, Finesse |\\n| **Streitaxt** | 1W8 | +7 | 1W8 + 4 | 1W8 + 6 | Einhändig |\\n| **Wurfspeer** | 1W6 | +7 | 1W6 + 4 | 1W6 + 6 | Wurf (6 m / 37 m Nachteil) |\\n\\n---\\n\\n## 📋 **Notizen**\\n- **Bonusaktion:** Zweiter Angriff mit einhändiger Waffe (ohne Stärke-Bonus auf Schaden).  \\n- **Raserei:** 3× pro langer Rast, vorher ansagen.  \\n- **Rücksichtslos:** Vorteil auf Angriff, Gegner haben Vorteil bis zum nächsten Zug.  \\n- **Wolfsomen:** Innerhalb 3 m halten für Aura-Aktivierung; Gegner im 18 m-Radius haben Nachteil.  \\n- **Resistenzen aktiv während Raserei:** Stich-, Hieb- und Wucht-Schaden halbiert.\"}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false},{"statUuid":"0199c855-966a-73de-9421-30516cc59ed8","serializedValue":"{\"value\":0}","hideFromCharacterScreen":false,"hideLabelOfStat":false,"variant":0,"isCopy":false}],"isAlternateFormActive":null,"alternateForm":null,"transformationComponents":null,"moneyInBaseType":900000,"tabConfigurations":[{"tabUuid":"8e725f17-ce7c-41d9-a9fd-b83566075096","tabIcon":"hourglass-half"},{"tabUuid":"ebf46bc6-1e1e-4ea2-b580-caa992480e80","tabIcon":"fingerprint"},{"tabUuid":"11cc5da3-624b-40d4-9477-468a0a6b4670","tabIcon":"magic-ball-future-svgrepo-com"},{"tabUuid":"f0c39bb7-1d95-4d7a-aaf2-80bf31f2662a","tabIcon":"vault-weapons-svgrepo-com"},{"tabUuid":"9421920d-99c2-4882-8a39-53564e7b2920","tabIcon":"magic-ball-future-svgrepo-com"},{"tabUuid":"money_tab_uuid","tabIcon":"jewelry-store-svgrepo-com"},{"tabUuid":"inventory_tab_uuid","tabIcon":"backpack-svgrepo-com"},{"tabUuid":"recipes_tab_uuid","tabIcon":"tools-svgrepo-com"},{"tabUuid":"lore_tab_uuid","tabIcon":"earth-europe"}],"inventory":[{"itemUuid":"019239b7-a5dd-79af-a15e-41fc5066c199","amount":2},{"itemUuid":"01922a3e-a5e8-7d91-bb80-8dcbaa3d7ab9","amount":0},{"itemUuid":"019239b4-f702-768b-8886-58ea804bf56e","amount":14},{"itemUuid":"019239b0-2c1e-72de-82c5-19285eea039e","amount":10},{"itemUuid":"01923e71-cb30-74a1-81e0-2d6dd2ecd260","amount":1},{"itemUuid":"01923e91-fb2c-739d-95e8-d97ca3a61ac8","amount":7},{"itemUuid":"019224fe-6d7d-7a71-a8c6-d99e7bd0d091","amount":1},{"itemUuid":"019251c0-a97e-7f6b-8f73-6eafaccd143e","amount":0},{"itemUuid":"019251ca-1b1f-788f-a385-1b75374c55b0","amount":1},{"itemUuid":"01